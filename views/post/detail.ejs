<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  
  <%- include('../partials/navbar') %>

  <% if (success && success.length > 0) { %>
    <div class="container mt-3">
      <div class="alert alert-success" role="alert">
        <%= success %>
      </div>
    </div>
  <% } %>

  <% if (error && error.length > 0) { %>
    <div class="container mt-3">
      <div class="alert alert-danger" role="alert">
        <%= error %>
      </div>
    </div>
  <% } %>

  <div class="container my-4">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <a href="/feed" class="btn btn-secondary mb-3">
          <i class="bi bi-arrow-left"></i> Back to Feed
        </a>

        <%- include('../partials/post-card', { post: { ...post, isLiked } }) %>

        <div class="card">
          <div class="card-body">
            <h5 class="mb-4">Comments (<%= comments.length %>)</h5>

            <form action="/comment/post/<%= post._id %>/comment" method="POST" class="mb-4">
              <div class="mb-3">
                <textarea 
                  class="form-control" 
                  name="content" 
                  rows="3" 
                  placeholder="Add a comment..." 
                  required 
                  maxlength="500"
                  data-max-length="500"
                  data-counter="commentCounter"></textarea>
                <div id="commentCounter" class="char-counter">500 characters remaining</div>
              </div>
              <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-send"></i> Post Comment
              </button>
            </form>

            <div class="comments-list">
              <% if (comments && comments.length > 0) { %>
                <% comments.forEach(comment => { %>
                  <div class="comment-item">
                    <div class="comment-header">
                      <img src="<%= comment.user.profile?.profilePicture || `https://ui-avatars.com/api/?name=${comment.user.username}&background=111827&color=fff&size=200` %>" 
                           alt="<%= comment.user.username %>" 
                           class="comment-avatar">
                      <div>
                        <a href="/user/<%= comment.user.username %>" class="comment-author">
                          <%= comment.user.username %>
                        </a>
                        <div class="comment-time">
                          <%= moment(comment.createdAt).fromNow() %>
                        </div>
                      </div>
                      <% if (currentUser && currentUser._id.equals(comment.user._id)) { %>
                        <form action="/comment/<%= comment._id %>/delete" method="POST" class="ms-auto">
                          <button type="submit" class="btn btn-sm btn-outline-danger confirm-delete">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      <% } %>
                    </div>
                    <div class="comment-content">
                      <%= comment.content %>
                    </div>
                  </div>
                <% }) %>
              <% } else { %>
                <p style="color: var(--color-text-secondary); text-align: center;">
                  No comments yet. Be the first to comment!
                </p>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
