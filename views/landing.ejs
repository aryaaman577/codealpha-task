<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  
  <div class="landing-hero">
    <div class="container">
      <div style="font-size: 5rem; margin-bottom: 1.5rem;">◎</div>
      <h1>CircleSphere</h1>
      <p>Connect. Share. Belong.</p>
      <p style="max-width: 600px; margin: 0 auto 2rem;">
        A premium social networking platform where meaningful connections happen. 
        Share your thoughts, discover new perspectives, and build your community.
      </p>
      <div class="d-flex gap-3 justify-content-center">
        <a href="/auth/register" class="btn btn-light btn-lg">
          Get Started
        </a>
        <a href="/auth/login" class="btn btn-outline-light btn-lg">
          Log In
        </a>
      </div>
    </div>
  </div>

  <div class="container my-5">
    <div class="row text-center">
      <div class="col-md-4 mb-4">
        <div class="card h-100">
          <div class="card-body">
            <i class="bi bi-people" style="font-size: 3rem; color: var(--color-primary);"></i>
            <h3 class="mt-3">Connect</h3>
            <p style="color: var(--color-text-secondary);">
              Build meaningful relationships with people who share your interests and passions.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card h-100">
          <div class="card-body">
            <i class="bi bi-chat-dots" style="font-size: 3rem; color: var(--color-primary);"></i>
            <h3 class="mt-3">Share</h3>
            <p style="color: var(--color-text-secondary);">
              Express yourself through posts, images, and engage in thoughtful conversations.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card h-100">
          <div class="card-body">
            <i class="bi bi-heart" style="font-size: 3rem; color: var(--color-primary);"></i>
            <h3 class="mt-3">Belong</h3>
            <p style="color: var(--color-text-secondary);">
              Find your community and feel at home in a welcoming, supportive environment.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <footer class="footer">
    <div class="container">
      <div class="row">
        <div class="col-md-12">
          <p class="footer-text">
            &copy; <%= new Date().getFullYear() %> CircleSphere. Connect. Share. Belong.
          </p>
          <p class="footer-text" style="font-size: 0.75rem; margin-top: 0.5rem;">
            Built with Node.js, Express, MongoDB & Bootstrap
          </p>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
