<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  
  <%- include('../partials/navbar') %>

  <div class="container my-4">
    <h2 class="mb-4">
      <% if (query) { %>
        Search Results for "<%= query %>"
      <% } else { %>
        Search
      <% } %>
    </h2>

    <% if (query) { %>
      <div class="row">
        <div class="col-lg-6 mb-4">
          <div class="card">
            <div class="card-body">
              <h5 class="mb-3">Users</h5>
              <% if (users && users.length > 0) { %>
                <% users.forEach(user => { %>
                  <%- include('../partials/user-card', { user }) %>
                <% }) %>
              <% } else { %>
                <p style="color: var(--color-text-secondary);">No users found</p>
              <% } %>
            </div>
          </div>
        </div>

        <div class="col-lg-6 mb-4">
          <div class="card">
            <div class="card-body">
              <h5 class="mb-3">Posts</h5>
              <% if (posts && posts.length > 0) { %>
                <% posts.forEach(post => { %>
                  <div class="mb-3 pb-3" style="border-bottom: 1px solid var(--color-border);">
                    <a href="/post/<%= post._id %>" style="text-decoration: none; color: inherit;">
                      <div class="d-flex gap-2 mb-2">
                        <img src="<%= post.user.profile?.profilePicture || `https://ui-avatars.com/api/?name=${post.user.username}&background=111827&color=fff&size=200` %>" 
                             alt="<%= post.user.username %>" 
                             style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;">
                        <div>
                          <strong><%= post.user.username %></strong>
                          <div style="font-size: 0.75rem; color: var(--color-text-secondary);">
                            <%= moment(post.createdAt).fromNow() %>
                          </div>
                        </div>
                      </div>
                      <p style="color: var(--color-text); margin-bottom: 0;">
                        <%= post.content.substring(0, 150) %><%= post.content.length > 150 ? '...' : '' %>
                      </p>
                    </a>
                  </div>
                <% }) %>
              <% } else { %>
                <p style="color: var(--color-text-secondary);">No posts found</p>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="empty-state">
        <div class="empty-state-icon">
          <i class="bi bi-search"></i>
        </div>
        <p class="empty-state-text">Use the search bar to find users and posts</p>
      </div>
    <% } %>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
