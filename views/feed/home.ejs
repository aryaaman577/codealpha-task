<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  
  <%- include('../partials/navbar') %>

  <% if (success && success.length > 0) { %>
    <div class="container mt-3">
      <div class="alert alert-success" role="alert">
        <%= success %>
      </div>
    </div>
  <% } %>

  <% if (error && error.length > 0) { %>
    <div class="container mt-3">
      <div class="alert alert-danger" role="alert">
        <%= error %>
      </div>
    </div>
  <% } %>

  <div class="container my-4">
    <div class="row">
      <div class="col-lg-8">
        <div class="card mb-4">
          <div class="card-body">
            <h5 class="mb-3">What's on your mind?</h5>
            <a href="/post/create" class="btn btn-primary">
              <i class="bi bi-plus-circle"></i> Create Post
            </a>
          </div>
        </div>

        <% if (posts && posts.length > 0) { %>
          <% posts.forEach(post => { %>
            <%- include('../partials/post-card', { post: post }) %>
          <% }) %>

          <% if (totalPages > 1) { %>
            <nav>
              <ul class="pagination justify-content-center">
                <% for (let i = 1; i <= totalPages; i++) { %>
                  <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                    <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                  </li>
                <% } %>
              </ul>
            </nav>
          <% } %>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-state-icon">
              <i class="bi bi-inbox"></i>
            </div>
            <p class="empty-state-text">No posts yet</p>
            <p style="color: var(--color-text-secondary); margin-bottom: 1rem;">
              Follow users to see their posts in your feed
            </p>
            <a href="/user/search" class="btn btn-primary">
              <i class="bi bi-search"></i> Find People
            </a>
          </div>
        <% } %>
      </div>

      <div class="col-lg-4">
        <div class="card">
          <div class="card-body">
            <h5 class="mb-3">Suggested Users</h5>
            <% if (suggestedUsers && suggestedUsers.length > 0) { %>
              <% suggestedUsers.forEach(({ user, profile }) => { %>
                <%- include('../partials/user-card', { user: { ...user, profile } }) %>
              <% }) %>
            <% } else { %>
              <p style="color: var(--color-text-secondary); font-size: 0.875rem;">
                No suggestions at the moment
              </p>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
