<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  
  <%- include('../partials/navbar') %>

  <% if (success && success.length > 0) { %>
    <div class="container mt-3">
      <div class="alert alert-success" role="alert">
        <%= success %>
      </div>
    </div>
  <% } %>

  <div class="container my-4">
    <div class="profile-header">
      <div class="profile-cover">
        <% if (profile.coverImage) { %>
          <img src="<%= profile.coverImage %>" alt="Cover" class="profile-cover-image">
        <% } %>
      </div>

      <div class="profile-info">
        <div class="profile-avatar-wrapper">
          <img src="<%= profile.profilePicture || `https://ui-avatars.com/api/?name=${profileUser.username}&background=111827&color=fff&size=200` %>" 
               alt="<%= profileUser.username %>" 
               class="profile-avatar">
        </div>

        <div class="d-flex justify-content-between align-items-start mb-3">
          <div>
            <h2 class="profile-name">
              <%= profile.firstName || profileUser.username %> <%= profile.lastName || '' %>
            </h2>
            <p class="profile-username">@<%= profileUser.username %></p>
          </div>

          <div>
            <% if (isOwnProfile) { %>
              <a href="/user/edit" class="btn btn-outline-primary">
                <i class="bi bi-pencil"></i> Edit Profile
              </a>
            <% } else if (currentUser) { %>
              <button class="btn <%= isFollowing ? 'btn-secondary' : 'btn-primary' %> follow-button" 
                      data-user-id="<%= profileUser._id %>">
                <%= isFollowing ? 'Unfollow' : 'Follow' %>
              </button>
            <% } %>
          </div>
        </div>

        <% if (profile.bio) { %>
          <p class="profile-bio"><%= profile.bio %></p>
        <% } %>

        <div class="profile-meta">
          <% if (profile.location) { %>
            <div class="profile-meta-item">
              <i class="bi bi-geo-alt"></i>
              <span><%= profile.location %></span>
            </div>
          <% } %>
          <% if (profile.website) { %>
            <div class="profile-meta-item">
              <i class="bi bi-link-45deg"></i>
              <a href="<%= profile.website %>" target="_blank" rel="noopener" style="color: var(--color-primary);">
                <%= profile.website.replace(/^https?:\/\//, '') %>
              </a>
            </div>
          <% } %>
          <div class="profile-meta-item">
            <i class="bi bi-calendar"></i>
            <span>Joined <%= moment(profileUser.createdAt).format('MMMM YYYY') %></span>
          </div>
        </div>

        <% if (profile.skills && profile.skills.length > 0) { %>
          <div class="mb-3">
            <% profile.skills.forEach(skill => { %>
              <span class="badge"><%= skill %></span>
            <% }) %>
          </div>
        <% } %>

        <div class="profile-stats">
          <div class="profile-stat">
            <span class="profile-stat-value"><%= posts.length %></span>
            <span class="profile-stat-label">Posts</span>
          </div>
          <a href="/user/<%= profileUser.username %>/followers" style="text-decoration: none;">
            <div class="profile-stat">
              <span class="profile-stat-value"><%= followersCount %></span>
              <span class="profile-stat-label">Followers</span>
            </div>
          </a>
          <a href="/user/<%= profileUser.username %>/following" style="text-decoration: none;">
            <div class="profile-stat">
              <span class="profile-stat-value"><%= followingCount %></span>
              <span class="profile-stat-label">Following</span>
            </div>
          </a>
        </div>
      </div>
    </div>

    <h4 class="mb-3">Posts</h4>
    <% if (posts && posts.length > 0) { %>
      <% posts.forEach(post => { %>
        <%- include('../partials/post-card', { post: { ...post, isLiked: currentUser && post.likes.some(like => like.equals(currentUser._id)) } }) %>
      <% }) %>
    <% } else { %>
      <div class="empty-state">
        <div class="empty-state-icon">
          <i class="bi bi-file-text"></i>
        </div>
        <p class="empty-state-text">No posts yet</p>
      </div>
    <% } %>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
