<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  
  <%- include('partials/navbar') %>

  <div class="container my-4">
    <h2 class="mb-4">Dashboard</h2>

    <div class="row">
      <div class="col-md-3 mb-3">
        <div class="card">
          <div class="card-body text-center">
            <i class="bi bi-file-text" style="font-size: 2.5rem; color: var(--color-primary);"></i>
            <h3 class="mt-3 mb-1"><%= stats.posts %></h3>
            <p style="color: var(--color-text-secondary); margin: 0;">Total Posts</p>
          </div>
        </div>
      </div>

      <div class="col-md-3 mb-3">
        <div class="card">
          <div class="card-body text-center">
            <i class="bi bi-people" style="font-size: 2.5rem; color: var(--color-primary);"></i>
            <h3 class="mt-3 mb-1"><%= stats.followers %></h3>
            <p style="color: var(--color-text-secondary); margin: 0;">Followers</p>
          </div>
        </div>
      </div>

      <div class="col-md-3 mb-3">
        <div class="card">
          <div class="card-body text-center">
            <i class="bi bi-person-plus" style="font-size: 2.5rem; color: var(--color-primary);"></i>
            <h3 class="mt-3 mb-1"><%= stats.following %></h3>
            <p style="color: var(--color-text-secondary); margin: 0;">Following</p>
          </div>
        </div>
      </div>

      <div class="col-md-3 mb-3">
        <div class="card">
          <div class="card-body text-center">
            <i class="bi bi-heart" style="font-size: 2.5rem; color: var(--color-primary);"></i>
            <h3 class="mt-3 mb-1"><%= stats.likes %></h3>
            <p style="color: var(--color-text-secondary); margin: 0;">Total Likes</p>
          </div>
        </div>
      </div>
    </div>

    <div class="row mt-4">
      <div class="col-12">
        <div class="card">
          <div class="card-body">
            <h4 class="mb-3">Recent Posts</h4>
            
            <% if (recentPosts && recentPosts.length > 0) { %>
              <div class="table-responsive">
                <table class="table">
                  <thead>
                    <tr>
                      <th>Content</th>
                      <th>Likes</th>
                      <th>Comments</th>
                      <th>Date</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% recentPosts.forEach(post => { %>
                      <tr>
                        <td>
                          <%= post.content.substring(0, 50) %><%= post.content.length > 50 ? '...' : '' %>
                        </td>
                        <td><%= post.likesCount %></td>
                        <td><%= post.commentsCount %></td>
                        <td><%= moment(post.createdAt).format('MMM D, YYYY') %></td>
                        <td>
                          <a href="/post/<%= post._id %>" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-eye"></i> View
                          </a>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <div class="empty-state">
                <div class="empty-state-icon">
                  <i class="bi bi-file-text"></i>
                </div>
                <p class="empty-state-text">No posts yet</p>
                <a href="/post/create" class="btn btn-primary">
                  <i class="bi bi-plus-circle"></i> Create Your First Post
                </a>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="row mt-4">
      <div class="col-12">
        <div class="card">
          <div class="card-body">
            <h4 class="mb-3">Quick Actions</h4>
            <div class="d-flex flex-wrap gap-2">
              <a href="/post/create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create Post
              </a>
              <a href="/user/<%= currentUser.username %>" class="btn btn-outline-primary">
                <i class="bi bi-person"></i> View Profile
              </a>
              <a href="/user/edit" class="btn btn-outline-primary">
                <i class="bi bi-pencil"></i> Edit Profile
              </a>
              <a href="/user/search" class="btn btn-outline-primary">
                <i class="bi bi-search"></i> Find People
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
